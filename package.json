{
  "name": "optiacademic-mern",
  "version": "1.0.0",
  "private": true,
  "description": "Prototipo grupal MERN para generacion automatica de horarios academicos.",
  "workspaces": [
    "Frontend",
    "Backend"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "npm run dev --workspace Frontend",
    "dev:server": "npm run dev --workspace Backend",
    "build": "npm run build --workspace Frontend",
    "test": "npm run test --workspace Backend",
    "test:coverage": "npm run test:coverage --workspace Backend"
  }
}
