# Docker Compose development example. Copy to .docker.env and change secrets locally.

# Application
APP_NAME=OptiAcademic
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Published ports
FRONTEND_PORT=5173
BACKEND_PORT=8000
MYSQL_EXPOSED_PORT=3307

# MySQL container and backend connection
MYSQL_ROOT_PASSWORD=replace_with_local_root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=optiacademic
MYSQL_PASSWORD=replace_with_local_app_password
MYSQL_DATABASE=optiacademic_db

# Authentication and CORS
SECRET_KEY=replace_with_a_long_random_local_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Browser-facing API address used by Vite
VITE_API_URL=http://127.0.0.1:8000/api/v1
